<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Tools Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body { background: #050505; color: white; font-family: 'Segoe UI', sans-serif; }
        .glass { background: rgba(255,255,255,0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
        .page { display: none; }
        .page.active { display: block; }
        .nav-btn.active { background: #3b82f6; color: white; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Top Navigation -->
    <nav class="sticky top-0 z-50 bg-[#050505]/90 backdrop-blur-md border-b border-white/10 p-4 flex justify-around items-center">
        <button onclick="showPage('video')" id="nav-video" class="nav-btn active text-xs md:text-sm font-bold px-3 py-2 rounded-lg transition"><i class="fas fa-download mr-1"></i> SnapVid</button>
        <button onclick="showPage('ai')" id="nav-ai" class="nav-btn text-gray-400 text-xs md:text-sm font-bold px-3 py-2 rounded-lg transition"><i class="fas fa-robot mr-1"></i> AIGenius</button>
        <button onclick="showPage('seo')" id="nav-seo" class="nav-btn text-gray-400 text-xs md:text-sm font-bold px-3 py-2 rounded-lg transition"><i class="fas fa-chart-line mr-1"></i> SitePulse</button>
    </nav>

    <!-- ========================================== -->
    <!-- PAGE 1: SNAPVID PRO (Video Downloader)     -->
    <!-- ========================================== -->
    <div id="page-video" class="page active flex-1 p-6 max-w-4xl mx-auto w-full">
        <div class="text-center mb-12 mt-10">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Download Any Video <span class="text-blue-500">Instantly</span></h1>
            <p class="text-gray-400">Supports Instagram, TikTok, Facebook, Twitter & more.</p>
        </div>

        <div class="glass p-2 rounded-2xl flex flex-col md:flex-row gap-2 mb-8">
            <input type="text" id="videoUrl" placeholder="Paste video link here..." class="flex-1 bg-transparent px-4 py-3 outline-none text-white placeholder-gray-500">
            <button onclick="fetchVideo()" class="bg-blue-600 hover:bg-blue-500 px-8 py-3 rounded-xl font-bold transition"><i class="fas fa-arrow-down mr-2"></i>Fetch</button>
        </div>

        <div id="videoResult" class="hidden glass p-6 rounded-2xl text-center mb-8">
            <p class="text-green-400 font-bold mb-4 text-lg">Video Ready!</p>
            <a id="videoDownloadLink" href="#" target="_blank" class="bg-green-500 hover:bg-green-400 text-black px-10 py-3 rounded-xl font-bold transition inline-block">Download HD</a>
        </div>

        <div class="grid grid-cols-3 gap-4 text-center mt-12">
            <div class="glass p-4 rounded-xl"><i class="fas fa-bolt text-yellow-400 text-2xl mb-2"></i><p class="text-xs text-gray-400">Fast</p></div>
            <div class="glass p-4 rounded-xl"><i class="fas fa-shield-alt text-green-400 text-2xl mb-2"></i><p class="text-xs text-gray-400">Secure</p></div>
            <div class="glass p-4 rounded-xl"><i class="fas fa-crown text-purple-400 text-2xl mb-2"></i><p class="text-xs text-gray-400">HD Quality</p></div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- PAGE 2: AIGENIUS HUB (AI Tools Directory)  -->
    <!-- ========================================== -->
    <div id="page-ai" class="page flex-1 p-6 max-w-4xl mx-auto w-full">
        <div class="text-center mb-10 mt-10">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Discover <span class="text-purple-500">AI Tools</span></h1>
            <p class="text-gray-400 mb-6">Find the best tools for Video, Research, Image & more.</p>
            <input type="text" id="aiSearch" onkeyup="filterAITools()" placeholder="Search tools (e.g. video, study)..." class="w-full bg-[#111] border border-gray-800 px-4 py-3 rounded-xl outline-none focus:border-purple-500">
        </div>

        <div id="aiToolsGrid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- JS will fill this -->
        </div>
    </div>

    <!-- ========================================== -->
    <!-- PAGE 3: SITEPULSE (SEO & Website Tools)    -->
    <!-- ========================================== -->
    <div id="page-seo" class="page flex-1 p-6 max-w-4xl mx-auto w-full">
        <div class="text-center mb-10 mt-10">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Website <span class="text-green-500">Metrics</span></h1>
            <p class="text-gray-400 mb-6">Check speed, traffic, and SEO health.</p>
            <div class="flex flex-col md:flex-row gap-2 bg-[#111] p-2 rounded-xl">
                <input type="text" id="seoUrl" placeholder="Enter domain (e.g. google.com)" class="flex-1 bg-transparent px-4 py-3 outline-none text-white placeholder-gray-500">
                <button onclick="analyzeSEO()" class="bg-green-600 hover:bg-green-500 px-8 py-3 rounded-lg font-bold transition">Analyze</button>
            </div>
        </div>

        <div id="seoResult" class="hidden glass p-6 rounded-2xl text-center mb-8">
            <p class="text-yellow-400 font-bold">Loading metrics...</p>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-8">
            <div class="glass p-5 rounded-xl text-center"><i class="fas fa-tachometer-alt text-green-400 text-2xl mb-2"></i><p class="text-sm font-bold">Speed Test</p><span class="text-[10px] text-green-400">FREE</span></div>
            <div class="glass p-5 rounded-xl text-center border-yellow-500/50"><i class="fas fa-users text-purple-400 text-2xl mb-2"></i><p class="text-sm font-bold">Traffic</p><span class="text-[10px] text-yellow-400">PRO</span></div>
            <div class="glass p-5 rounded-xl text-center"><i class="fas fa-history text-blue-400 text-2xl mb-2"></i><p class="text-sm font-bold">Domain Age</p><span class="text-[10px] text-green-400">FREE</span></div>
            <div class="glass p-5 rounded-xl text-center"><i class="fas fa-unlock text-red-400 text-2xl mb-2"></i><p class="text-sm font-bold">Unblocker</p><span class="text-[10px] text-green-400">FREE</span></div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- JAVASCRIPT LOGIC (100% Working)            -->
    <!-- ========================================== -->
